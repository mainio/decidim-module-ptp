<% if voting_mode? %>
  <div id="project-<%= model.id %>-item" class="budget-list__item">
    <div class= "p-4 cursor-pointer flex flex-col" data-dialog-open="project-modal-<%= model.id %>">
      <p class="text-[22px] font-bio text-[--primary] inline-block align-middle md:h3">
        <%= decidim_escape_translated(title) %>
      </p>
      <div class="card__list-text ">
        <%= decidim_sanitize_editor(translated_attribute(project.description)) %>
      </div>

      <div class="mt-auto gap-4 flex">
        <% if show_votes? %>
          <%= cell("decidim/budgets/project_votes_count", project, layout: :one_line, class: "display-block card__list-text") %>
        <% end %>

        <%= cell("decidim/budgets/project_voted_hint", project, class: "display-block card__list-text voted-tag") %>
      </div>
    </div>

    <div class="<%= voting_mode? && resource_added? ? "selected-project" : "explore-link" %> p-4">
      <div class="budget__card__vote">
        <div class="budget__card__highlight-vote__header">
          <span class="budget__card__highlight-vote__text">
            <%= t("name", scope: "decidim.budgets.admin.models.budget") %>
          </span>
          <span class="budget__card__highlight-vote__number">
            <%= budget_to_currency(project.budget_amount) %>
          </span>
        </div>

        <div class="flex justify-center items-center py-2">
          <%= cell("decidim/budgets/project_vote_button", model) %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <%= link_to resource_path, class: "w-full" do %>
    <div id="project-<%= model.id %>-item" class="budget-list__item">
      <div class= "p-4 flex flex-col">
        <p class="h3 text-[--primary] inline-block align-middle">
          <%= decidim_escape_translated(title) %>
        </p>
        <div class="card__list-text ">
          <%= decidim_sanitize_editor(translated_attribute(project.description)) %>
        </div>

        <div class="mt-auto gap-4 flex">
          <% if selected? %>
            <span class="label success">
              <%= t("selected", scope: "activemodel.attributes.project") %>
            </span>
          <% end %>

          <% if show_votes? %>
            <%= cell("decidim/budgets/project_votes_count", project, layout: :one_line, class: "display-block card__list-text") %>
          <% end %>

          <%= cell("decidim/budgets/project_voted_hint", project, class: "display-block card__list-text voted-tag") %>
        </div>
      </div>

      <div class="<%= voting_mode? && resource_added? ? "selected-project" : "explore-link" %> p-4">
        <div class="budget__card__prevote">
          <div class="budget__card__highlight-prevote__header">
            <span class="budget__card__highlight-prevote__text">
              <%= t("name", scope: "decidim.budgets.admin.models.budget") %>
            </span>
            <span class="budget__card__highlight-prevote__number">
              <%= budget_to_currency(project.budget_amount) %>
            </span>
          </div>
          <div class="budget__card__prevote-explore-button-container">
            <div class="button button__lg button__secondary budget__card__prevote-explore-button">
              <span><%= t(".explore") %></span>
              <%= icon "arrow-right-line" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
